[Unit]
Description=KiezQuiz Telegram Agent (Kalle)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jjl
WorkingDirectory=/home/jjl/projects/KiezQuiz/telegram-agent
Environment=PATH=/home/jjl/.local/bin:/usr/local/bin:/usr/bin:/bin
EnvironmentFile=-/home/jjl/projects/KiezQuiz/telegram-agent/.env
ExecStart=/home/jjl/projects/KiezQuiz/telegram-agent/.venv/bin/python bot.py
Restart=always
RestartSec=15

[Install]
WantedBy=multi-user.target
